# Client-side Firebase configuration (safe to expose)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_API_BASE_URL=http://localhost:8787

# Server-only credentials. Never prefix these with VITE_.
BINGX_API_KEY=replace_with_a_new_bingx_api_key
BINGX_SECRET_KEY=replace_with_a_new_bingx_secret_key
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
PORT=8787
